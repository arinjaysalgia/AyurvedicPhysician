---
import SectionHeading from '../common/SectionHeading.astro';
import { credentials } from '../../data/credentials';
import { Award, Leaf, GraduationCap, HeartPulse } from 'lucide-react';

const iconMap: Record<string, typeof Award> = { Award, Leaf, GraduationCap, HeartPulse };
---

<section class="py-20 bg-forest-50/50" aria-labelledby="credentials-heading">
  <div class="max-w-7xl mx-auto px-6">
    <SectionHeading
      label="Qualifications"
      title="Credentials & Expertise"
      subtitle="A rare combination of academic excellence and clinical depth."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {credentials.map(({ icon, label, title, description }) => {
        const IconComponent = iconMap[icon];
        return (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-earth-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center">
            <div class="w-14 h-14 flex items-center justify-center rounded-full bg-gold-100 text-gold-600 mx-auto mb-4">
              {IconComponent && <IconComponent size={28} />}
            </div>
            <p class="text-xs font-medium tracking-wide uppercase text-forest-500 mb-1">{label}</p>
            <h3 class="text-lg font-heading font-semibold text-forest-900 mb-2">{title}</h3>
            <p class="text-sm text-earth-800/70">{description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
