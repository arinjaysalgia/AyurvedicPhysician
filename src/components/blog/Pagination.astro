---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  const separator = baseUrl.includes('?') ? '&' : '?';
  return page === 1 ? baseUrl : `${baseUrl}${separator}page=${page}`;
}
---

{totalPages > 1 && (
  <nav class="flex justify-center gap-2 mt-12" aria-label="Blog pagination">
    {currentPage > 1 && (
      <a
        href={pageUrl(currentPage - 1)}
        class="px-4 py-2 rounded-lg border border-earth-100 text-earth-800 hover:bg-forest-50 transition-colors text-sm"
      >
        ← Previous
      </a>
    )}

    {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
      <a
        href={pageUrl(page)}
        class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
          page === currentPage
            ? 'bg-forest-500 text-white'
            : 'border border-earth-100 text-earth-800 hover:bg-forest-50'
        }`}
        aria-current={page === currentPage ? 'page' : undefined}
      >
        {page}
      </a>
    ))}

    {currentPage < totalPages && (
      <a
        href={pageUrl(currentPage + 1)}
        class="px-4 py-2 rounded-lg border border-earth-100 text-earth-800 hover:bg-forest-50 transition-colors text-sm"
      >
        Next →
      </a>
    )}
  </nav>
)}
