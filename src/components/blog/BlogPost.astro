---
import type { BlogPost } from '../../data/blog-types';
import { renderMarkdown } from '../../data/markdown';
import { Calendar, Clock, User, Tag } from 'lucide-react';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.publishDate).toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const renderedContent = renderMarkdown(post.content);
---

<article class="py-12">
  <div class="max-w-3xl mx-auto px-6">
    {post.featuredImage && (
      <img
        src={post.featuredImage}
        alt={post.title}
        class="w-full h-64 md:h-96 object-cover rounded-2xl mb-8"
        loading="eager"
      />
    )}

    <header class="mb-8">
      <span class="inline-block px-3 py-1 bg-forest-100 text-forest-700 text-sm font-medium rounded-full mb-4">
        {post.category}
      </span>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-forest-900 mb-6 leading-tight">
        {post.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-earth-800/60">
        <span class="flex items-center gap-1.5">
          <User size={14} />
          {post.author}
        </span>
        <span class="flex items-center gap-1.5">
          <Calendar size={14} />
          {formattedDate}
        </span>
        <span class="flex items-center gap-1.5">
          <Clock size={14} />
          {post.readTime} min read
        </span>
      </div>
    </header>

    <div
      class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-forest-900
        prose-p:text-earth-800/80 prose-p:leading-relaxed
        prose-a:text-forest-500 prose-a:underline prose-a:underline-offset-4
        prose-strong:text-forest-900
        prose-blockquote:border-l-4 prose-blockquote:border-gold-500 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-earth-800/70
        prose-code:bg-forest-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-img:rounded-xl
        prose-hr:border-earth-100"
      set:html={renderedContent}
    />

    {post.tags.length > 0 && (
      <div class="mt-12 pt-8 border-t border-earth-100">
        <div class="flex items-center gap-2 flex-wrap">
          <Tag size={16} class="text-earth-800/40" />
          {post.tags.map((tag) => (
            <span class="px-3 py-1 bg-earth-100 text-earth-800/70 text-xs font-medium rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </div>
</article>
