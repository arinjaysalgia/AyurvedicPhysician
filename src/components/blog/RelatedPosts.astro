---
import type { BlogPostSummary } from '../../data/blog-types';
import BlogCard from './BlogCard.astro';

interface Props {
  posts: BlogPostSummary[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="py-16 bg-forest-50/50" aria-labelledby="related-heading">
    <div class="max-w-7xl mx-auto px-6">
      <h2 id="related-heading" class="text-2xl font-heading font-semibold text-forest-900 mb-8 text-center">
        Related Articles
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </div>
  </section>
)}
