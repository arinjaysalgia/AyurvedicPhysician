---
import SectionHeading from '../common/SectionHeading.astro';

const modules = [
  {
    number: 1,
    title: 'Why Your Back Pain Keeps Coming Back',
    description: 'Understanding why temporary relief never becomes permanent healing.',
  },
  {
    number: 2,
    title: 'The Real Root Cause Behind Your Pain',
    description: "It's neither your age nor weakness — discover what's really going on.",
  },
  {
    number: 3,
    title: 'Daily Habits Damaging Your Spine',
    description: 'How your sitting, sleeping, walking, and working patterns affect your back.',
  },
  {
    number: 4,
    title: 'Reduce Pain Naturally Without Medicines',
    description: 'A corrective approach that addresses causes, not just symptoms.',
  },
  {
    number: 5,
    title: 'Protect Your Spine for the Long Term',
    description: 'Prevention strategies to stop recurring pain cycles permanently.',
  },
  {
    number: 6,
    title: 'When Surgery Is Truly Unnecessary',
    description: 'Understand when surgical recommendations may be premature.',
  },
];
---

<section class="py-20 bg-cream" aria-labelledby="modules-heading">
  <div class="max-w-7xl mx-auto px-6">
    <SectionHeading
      title="What's Inside the Guide"
      subtitle="Six focused chapters designed to give you clarity and control."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {modules.map(({ number, title, description }) => (
        <div class="bg-white rounded-2xl p-6 border border-earth-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="w-10 h-10 flex items-center justify-center rounded-full bg-gold-600 text-white font-bold text-sm mb-4">
            {number}
          </div>
          <h3 class="text-lg font-heading font-semibold text-forest-900 mb-2">{title}</h3>
          <p class="text-sm text-earth-800/70 leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
