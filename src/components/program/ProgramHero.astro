---
import Button from '../common/Button.astro';
---

<section class="relative py-20 md:py-28 bg-gradient-to-br from-forest-900 via-forest-900 to-forest-700 text-white overflow-hidden">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute top-10 right-10 text-[200px] leading-none">🌿</div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 text-gold-500 text-sm font-medium rounded-full mb-6 backdrop-blur-sm">
      Digital Guide · Instant Access
    </span>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-bold mb-6 leading-tight">
      It's Time to Say <em class="text-gold-500 not-italic">Bye-Bye</em> to Your Back Pain
    </h1>

    <p class="text-lg md:text-xl text-white/70 mb-4 max-w-2xl mx-auto">
      Back Pain Is Not Your Problem — Wrong Daily Habits Are!
    </p>

    <p class="text-white/60 mb-8 max-w-xl mx-auto">
      A simple, practical guide to understand why your back hurts and how to fix it naturally —
      designed by an Ayurvedic physician with 12+ years of clinical experience.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href="https://rzp.io/rzp/4W07TOyV" variant="primary" size="lg" external>
        Download Now — ₹999
      </Button>
      <p class="text-sm text-white/50">Instant PDF download after payment</p>
    </div>
  </div>
</section>
