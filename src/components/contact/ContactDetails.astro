---
import { MessageCircle, Mail } from 'lucide-react';
---

<div class="bg-white rounded-2xl p-6 border border-earth-100 space-y-4">
  <h3 class="font-heading font-semibold text-forest-900 text-lg">Other Ways to Reach Us</h3>

  <a
    href="https://wa.me/919999999999?text=Hi%20Dr.%20Pradnya%2C%20I%20would%20like%20to%20book%20a%20consultation."
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366]/20 transition-colors duration-200"
  >
    <MessageCircle size={20} />
    <span class="font-medium text-sm">Chat on WhatsApp</span>
  </a>

  <a
    href="mailto:contact@quantumspine.growgenx.shop"
    class="flex items-center gap-3 px-4 py-3 rounded-xl bg-forest-50 text-forest-700 hover:bg-forest-100 transition-colors duration-200"
  >
    <Mail size={20} />
    <span class="font-medium text-sm">Email Us</span>
  </a>
</div>
