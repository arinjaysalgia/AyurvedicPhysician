---
import Button from '../common/Button.astro';
---

<section class="py-20 bg-gold-100" aria-labelledby="cta-heading">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 id="cta-heading" class="text-3xl md:text-4xl font-heading font-bold text-forest-900 mb-4">
      Your Healing Journey Starts Today
    </h2>
    <p class="text-earth-800/70 text-lg mb-8 max-w-xl mx-auto">
      Book a 1:1 consultation and receive a personalized Ayurvedic plan within 48 hours.
      No prescriptions you don't need. No vague advice.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/contact" variant="primary" size="lg">
        Book Consultation Now →
      </Button>
      <a
        href="/from-pain-to-power"
        class="inline-flex items-center justify-center px-6 py-3 border-2 border-forest-900 text-forest-900 font-semibold rounded-lg hover:bg-forest-900 hover:text-white transition-colors duration-300"
      >
        Explore the Healing Program
      </a>
    </div>
  </div>
</section>
