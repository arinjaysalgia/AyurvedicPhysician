---
import SectionHeading from '../common/SectionHeading.astro';
import { conditions } from '../../data/conditions';
---

<section class="py-20 bg-forest-50/50" aria-labelledby="conditions-heading">
  <div class="max-w-7xl mx-auto px-6">
    <SectionHeading
      label="Conditions We Treat"
      title="Trusted for Stubborn Conditions"
      subtitle="Expert care for conditions modern medicine often struggles with."
    />

    <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
      {conditions.map(({ name }) => (
        <span class="px-6 py-3 bg-forest-100 text-forest-700 font-medium rounded-full text-sm hover:bg-forest-500 hover:text-white transition-colors duration-300 cursor-default">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>
