---
import SectionHeading from '../common/SectionHeading.astro';
import Button from '../common/Button.astro';
---

<section class="py-20 bg-forest-50/30" aria-labelledby="blog-preview-heading">
  <div class="max-w-7xl mx-auto px-6">
    <SectionHeading
      label="From Our Blog"
      title="Ayurvedic Health Insights"
      subtitle="Expert articles on natural healing, chronic disease reversal, and Ayurvedic lifestyle tips."
    />

    <div class="text-center mt-8">
      <Button href="/blog" variant="primary" size="lg">
        Read Our Blog →
      </Button>
    </div>
  </div>
</section>
