---
import SectionHeading from '../common/SectionHeading.astro';
import { testimonials } from '../../data/testimonials';
import { Star, Quote } from 'lucide-react';
---

<section class="py-20 bg-cream" aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-6">
    <SectionHeading
      label="Patient Stories"
      title="Real People. Real Transformations."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(({ quote, name, descriptor, rating }) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-earth-100 hover:shadow-lg transition-shadow duration-300">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: rating }).map((_, i) => (
              <Star size={16} fill="#D4A843" stroke="#D4A843" />
            ))}
          </div>
          <div class="mb-6">
            <Quote size={24} class="text-forest-100 mb-2" />
            <p class="text-earth-800/80 leading-relaxed italic">
              "{quote}"
            </p>
          </div>
          <div class="border-t border-earth-100 pt-4">
            <p class="font-semibold text-forest-900 text-sm">{name}</p>
            <p class="text-xs text-earth-800/60">{descriptor}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
