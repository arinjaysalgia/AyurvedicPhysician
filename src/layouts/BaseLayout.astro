---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import WhatsAppFab from '../components/common/WhatsAppFab.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideWhatsApp?: boolean;
}

const {
  title,
  description = 'Dr. Pradnya Chittawadagi — Ayurvedic Physician specializing in chronic disease reversal through classical Ayurveda and modern science.',
  ogImage = '/images/og-default.jpg',
  hideWhatsApp = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-cream text-earth-800 font-body antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-forest-900 focus:text-white focus:px-4 focus:py-2 focus:rounded-md"
    >
      Skip to main content
    </a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    {!hideWhatsApp && <WhatsAppFab />}
  </body>
</html>
