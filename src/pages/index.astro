---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/common/SEOHead.astro';
import Hero from '../components/home/Hero.astro';
import Services from '../components/home/Services.astro';
import Conditions from '../components/home/Conditions.astro';
import Process from '../components/home/Process.astro';
import DoctorIntro from '../components/home/DoctorIntro.astro';
import Testimonials from '../components/home/Testimonials.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import CTABanner from '../components/home/CTABanner.astro';

export const prerender = true;

const businessSchema = {
  '@type': 'MedicalBusiness',
  name: 'Dr. Pradnya Chittawadagi — Ayurvedic Practice',
  description: 'Ayurvedic physician specializing in chronic disease reversal through classical Ayurveda and modern science.',
  url: 'https://quantumspine.growgenx.shop',
  image: 'https://quantumspine.growgenx.shop/images/dr-pradnya-hero.jpg',
  medicalSpecialty: 'Ayurvedic Medicine',
  priceRange: '₹₹',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'IN',
  },
  founder: {
    '@type': 'Person',
    name: 'Dr. Pradnya Chittawadagi',
    jobTitle: 'Ayurvedic Physician & Research Scientist',
  },
};
---

<BaseLayout title="Dr. Pradnya Chittawadagi — Ayurvedic Physician | Chronic Disease Reversal">
  <Fragment slot="head">
    <SEOHead structuredData={businessSchema} />
  </Fragment>
  <Hero />
  <Services />
  <Conditions />
  <Process />
  <DoctorIntro />
  <Testimonials />
  <CTABanner />
  <BlogPreview />
</BaseLayout>
